// UVFunc:7
	vec2 n_in7p1 = vec2(10.00000, 5.00000);
	vec2 n_in7p2 = vec2(0.00000, 0.00000);
	vec2 n_out7p0 = (UV - n_in7p2) * n_in7p1 + n_in7p2;


// Vector2Constant:6
