code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_10;
uniform sampler2D depth_tex_frg_18 : hint_depth_texture;



void fragment() {
// Input:26
	vec2 n_out26p0 = UV;


// FloatConstant:25
	float n_out25p0 = 128.000000;


// VectorOp:23
	vec2 n_out23p0 = n_out26p0 * vec2(n_out25p0);


// VectorFunc:24
	vec2 n_out24p0 = floor(n_out23p0);


// VectorOp:27
	vec2 n_out27p0 = n_out24p0 / vec2(n_out25p0);


// UVFunc:7
	vec2 n_in7p1 = vec2(10.00000, 5.00000);
	vec2 n_in7p2 = vec2(0.00000, 0.00000);
	vec2 n_out7p0 = (n_out27p0 - n_in7p2) * n_in7p1 + n_in7p2;


// Vector2Constant:6
	vec2 n_out6p0 = vec2(0.100000, 0.100000);


// Input:5
	float n_out5p0 = TIME;


// UVFunc:4
	vec2 n_out4p0 = vec2(n_out5p0) * n_out6p0 + n_out7p0;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out4p0);


// UVFunc:13
	vec2 n_in13p1 = vec2(10.00000, 5.00000);
	vec2 n_in13p2 = vec2(0.00000, 0.00000);
	vec2 n_out13p0 = (n_out27p0 - n_in13p2) * n_in13p1 + n_in13p2;


// Vector2Constant:12
	vec2 n_out12p0 = vec2(-0.100000, 0.100000);


// Input:16
	float n_out16p0 = TIME;


// UVFunc:14
	vec2 n_out14p0 = vec2(n_out16p0) * n_out12p0 + n_out13p0;


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, n_out14p0);


// VectorOp:15
	vec3 n_out15p0 = vec3(n_out3p0.xyz) + vec3(n_out10p0.xyz);


// FloatConstant:9
	float n_out9p0 = 3.500000;


// VectorOp:8
	vec3 n_out8p0 = pow(n_out15p0, vec3(n_out9p0));


	float n_out18p0;
// ProximityFade:18
	float n_in18p0 = 0.08000;
	{
		float __depth_tex = texture(depth_tex_frg_18, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(SCREEN_UV * 2.0 - 1.0, __depth_tex, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out18p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_in18p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatOp:20
	float n_in20p1 = -0.70000;
	float n_out20p0 = pow(n_out18p0, n_in20p1);


// ColorConstant:22
	vec4 n_out22p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// VectorOp:21
	vec3 n_out21p0 = vec3(n_out20p0) + vec3(n_out22p0.xyz);


// VectorOp:19
	vec3 n_out19p0 = n_out8p0 * n_out21p0;


// Output:0
	ALBEDO = n_out19p0;
	EMISSION = n_out19p0;


}
