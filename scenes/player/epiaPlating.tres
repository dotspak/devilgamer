code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_frg_6;
uniform sampler2D tex_frg_8;
uniform float Metallic = 1.0;
uniform float specullar = 0.5;
uniform sampler2D tex_frg_11;



void fragment() {
// ColorConstant:2
	vec4 n_out2p0 = vec4(0.873438, 0.145484, 0.005371, 1.000000);


// Texture2D:6
	vec4 n_out6p0 = texture(tex_frg_6, UV);


// VectorOp:7
	vec3 n_out7p0 = vec3(n_out2p0.xyz) * vec3(n_out6p0.xyz);


// UVFunc:10
	vec2 n_in10p1 = vec2(4.00000, 1.00000);
	vec2 n_in10p2 = vec2(0.00000, 0.00000);
	vec2 n_out10p0 = (UV - n_in10p2) * n_in10p1 + n_in10p2;


// Texture2D:8
	vec4 n_out8p0 = texture(tex_frg_8, n_out10p0);


// VectorOp:9
	vec3 n_out9p0 = n_out7p0 * vec3(n_out8p0.xyz);


// FloatParameter:3
	float n_out3p0 = Metallic;


// FloatParameter:5
	float n_out5p0 = specullar;


// Texture2D:11
	vec4 n_out11p0 = texture(tex_frg_11, n_out10p0);


// Output:0
	ALBEDO = n_out9p0;
	METALLIC = n_out3p0;
	ROUGHNESS = n_out6p0.x;
	SPECULAR = n_out5p0;
	NORMAL_MAP = vec3(n_out11p0.xyz);


}
