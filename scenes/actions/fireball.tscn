[sub_resource type="VisualShader" id="VisualShader_g66xh"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled, fog_disabled;

uniform sampler2D tex_frg_9;
uniform sampler2D tex_frg_3;



void fragment() {
// Input:5
	float n_out5p0 = TIME;


// FloatOp:6
	float n_in6p1 = 0.10000;
	float n_out6p0 = n_out5p0 * n_in6p1;


// UVFunc:4
	vec2 n_in4p1 = vec2(3.00000, 3.00000);
	vec2 n_out4p0 = vec2(n_out6p0) * n_in4p1 + UV;


// Texture2D:9
	vec4 n_out9p0 = texture(tex_frg_9, n_out4p0);


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out4p0);
	float n_out3p1 = n_out3p0.r;


// Fresnel:7
	float n_in7p3 = 1.00000;
	float n_out7p0 = pow(clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_in7p3);


// FloatOp:8
	float n_out8p0 = n_out3p1 * n_out7p0;


// Output:0
	ALBEDO = vec3(n_out9p0.xyz);
	ALPHA = n_out8p0;


}
"
