render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled, fog_disabled;

uniform vec4 color : source_color = vec4(1.500000, 1.000000, 0.100000, 1.000000);
uniform sampler2D tex_frg_5;
uniform float fresnel = 1.0;



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = color;


// Texture2D:5
	vec4 n_out5p0 = texture(tex_frg_5, UV);


// FloatParameter:4
	float n_out4p0 = fresnel;


// Fresnel:3
