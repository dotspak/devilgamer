code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled, fog_disabled;

uniform vec4 color : source_color = vec4(1.000000, 0.541933, 0.000000, 1.000000);
uniform vec2 Vector2Parameter = vec2(2.000000, 2.000000);
uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_4;



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = color;


// Input:8
	float n_out8p0 = TIME;


// Vector2Parameter:10
	vec2 n_out10p0 = Vector2Parameter;


// FloatOp:9
	float n_out9p0 = n_out8p0 * n_out10p0.x;


// UVFunc:7
	vec2 n_in7p1 = vec2(0.00000, 1.00000);
	vec2 n_out7p0 = vec2(n_out9p0) * n_in7p1 + UV;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out7p0);
	float n_out3p1 = n_out3p0.r;


// Texture2D:4
	vec4 n_out4p0 = texture(tex_frg_4, UV);
	float n_out4p1 = n_out4p0.r;


// FloatOp:5
	float n_out5p0 = n_out3p1 - n_out4p1;


// Clamp:6
	float n_in6p1 = 0.00000;
	float n_in6p2 = 1.00000;
	float n_out6p0 = clamp(n_out5p0, n_in6p1, n_in6p2);


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);
	ALPHA = n_out6p0;


}
