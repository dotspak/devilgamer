code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_vtx_2;
uniform sampler2D depth_tex_frg_3 : hint_depth_texture;



void vertex() {
// Input:3
	vec3 n_out3p0 = VERTEX;


// Input:5
	vec3 n_out5p0 = NORMAL;


// Input:10
	float n_out10p0 = TIME;


// VectorOp:11
	vec2 n_in11p1 = vec2(0.10000, 1.00000);
	vec2 n_out11p0 = vec2(n_out10p0) * n_in11p1;


// UVFunc:9
	vec2 n_in9p1 = vec2(1.00000, 1.00000);
	vec2 n_out9p0 = n_out11p0 * n_in9p1 + UV;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_vtx_2, n_out9p0);
	float n_out2p1 = n_out2p0.r;


// VectorOp:6
	vec3 n_out6p0 = n_out5p0 * vec3(n_out2p1);


// FloatConstant:8
	float n_out8p0 = -0.200000;


// VectorOp:7
	vec3 n_out7p0 = n_out6p0 * vec3(n_out8p0);


// VectorOp:4
	vec3 n_out4p0 = n_out3p0 + n_out7p0;


// Output:0
	VERTEX = n_out4p0;


}

void fragment() {
// Input:5
	vec4 n_out5p0 = COLOR;
	float n_out5p4 = n_out5p0.a;


	float n_out3p0;
// ProximityFade:3
	float n_in3p0 = 0.50000;
	{
		float __depth_tex = texture(depth_tex_frg_3, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(SCREEN_UV * 2.0 - 1.0, __depth_tex, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out3p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_in3p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatOp:4
	float n_out4p0 = n_out5p4 * n_out3p0;


// Output:0
	ALBEDO = vec3(n_out5p0.xyz);
	ALPHA = n_out4p0;


}
