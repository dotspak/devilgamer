code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_frg_2;
uniform sampler2D tex_frg_6;



void vertex() {
// Input:6
	vec3 n_out6p0 = VERTEX;
	float n_out6p1 = n_out6p0.r;
	float n_out6p2 = n_out6p0.g;
	float n_out6p3 = n_out6p0.b;


// Input:3
	float n_out3p0 = TIME;


// FloatFunc:2
	float n_out2p0 = sin(n_out3p0);


// FloatOp:4
	float n_in4p1 = 0.20000;
	float n_out4p0 = n_out2p0 * n_in4p1;


// FloatOp:7
	float n_out7p0 = n_out6p2 + n_out4p0;


// VectorCompose:5
	vec3 n_out5p0 = vec3(n_out6p1, n_out7p0, n_out6p3);


// Output:0
	VERTEX = n_out5p0;


}

void fragment() {
// FloatConstant:5
	float n_out5p0 = 0.030000;


// Input:4
	float n_out4p0 = TIME;


// UVFunc:3
	vec2 n_out3p0 = vec2(n_out4p0) * vec2(n_out5p0) + UV;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out3p0);


// Texture2D:6
	vec4 n_out6p0 = texture(tex_frg_6, vec2(n_out2p0.xy));


// FloatOp:7
	float n_in7p1 = 0.10000;
	float n_out7p0 = n_out2p0.x * n_in7p1;


// Output:0
	ALBEDO = vec3(n_out6p0.xyz);
	EMISSION = vec3(n_out7p0);


}
