[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_toon, specular_toon;

uniform float WaveStrength = 0.40000000596046;
uniform float WaveSpeed = 0.10000000149012;
uniform sampler2D tex_vtx_4;
uniform sampler2D depth_tex_frg_16 : hint_depth_texture;
uniform vec4 waveColor : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform vec4 color : source_color = vec4(0.473625, 0.626326, 1.000000, 1.000000);
uniform float texturescale = 1.0;
uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_9;
uniform float alpha = 1.0;



void vertex() {
// FloatParameter:10
	float n_out10p0 = WaveSpeed;


// Input:2
	float n_out2p0 = TIME;


// UVFunc:3
	vec2 n_out3p0 = vec2(n_out2p0) * vec2(n_out10p0) + UV;


// Texture2D:4
	vec4 n_out4p0 = texture(tex_vtx_4, n_out3p0);


// Input:5
	vec3 n_out5p0 = NORMAL;


// FloatParameter:9
	float n_out9p0 = WaveStrength;


// VectorOp:8
	vec3 n_out8p0 = n_out5p0 * vec3(n_out9p0);


// Input:6
	vec3 n_out6p0 = VERTEX;


// MultiplyAdd:7
	vec4 n_out7p0 = fma(n_out4p0, vec4(n_out8p0, 0.0), vec4(n_out6p0, 0.0));


// Output:0
	VERTEX = vec3(n_out7p0.xyz);


}

void fragment() {
// Input:25
	float n_out25p0 = TIME;


// ParameterRef:30
	float n_out30p0 = WaveStrength;


	float n_out16p0;
// ProximityFade:16
	float n_in16p0 = 1.00000;
	{
		float __depth_tex = texture(depth_tex_frg_16, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(SCREEN_UV * 2.0 - 1.0, __depth_tex, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out16p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_in16p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatFunc:17
	float n_out17p0 = 1.0 - n_out16p0;


// MultiplyAdd:26
	float n_out26p0 = fma(n_out25p0, n_out30p0, n_out17p0);


// ParameterRef:29
	float n_out29p0 = WaveSpeed;


// FloatOp:27
	float n_out27p0 = n_out26p0 * n_out29p0;


// FloatFunc:19
	float n_out19p0 = sin(n_out27p0);


// FloatFunc:21
	float n_out21p0 = abs(n_out19p0);


// FloatOp:23
	float n_in23p1 = 2.00000;
	float n_out23p0 = pow(n_out17p0, n_in23p1);


// VectorOp:24
	vec3 n_out24p0 = vec3(n_out21p0) + vec3(n_out23p0);


// ColorParameter:14
	vec4 n_out14p0 = waveColor;


// VectorOp:22
	vec3 n_out22p0 = n_out24p0 * vec3(n_out14p0.xyz);


// VectorOp:28
	vec3 n_out28p0 = n_out22p0 * vec3(n_out17p0);


// ColorParameter:2
	vec4 n_out2p0 = color;


// FloatParameter:35
	float n_out35p0 = texturescale;


// UVFunc:34
	vec2 n_in34p2 = vec2(0.00000, 0.00000);
	vec2 n_out34p0 = (UV - n_in34p2) * vec2(n_out35p0) + n_in34p2;


// ParameterRef:31
	float n_out31p0 = WaveSpeed;


// Input:6
	float n_out6p0 = TIME;


// UVFunc:5
	vec2 n_out5p0 = vec2(n_out6p0) * vec2(n_out31p0) + n_out34p0;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out5p0);


// ParameterRef:32
	float n_out32p0 = WaveSpeed;


// FloatOp:33
	float n_in33p1 = -1.00000;
	float n_out33p0 = n_out32p0 * n_in33p1;


// Input:8
	float n_out8p0 = TIME;


// UVFunc:7
	vec2 n_out7p0 = vec2(n_out8p0) * vec2(n_out33p0) + n_out34p0;


// Texture2D:9
	vec4 n_out9p0 = texture(tex_frg_9, n_out7p0);


// VectorOp:10
	vec4 n_out10p0 = n_out3p0 * n_out9p0;


// VectorOp:11
	vec4 n_in11p1 = vec4(1.25000, 1.25000, 1.25000, 1.25000);
	vec4 n_out11p0 = pow(n_out10p0, n_in11p1);


// VectorOp:15
	vec4 n_out15p0 = n_out11p0 * n_out14p0;


// VectorOp:4
	vec4 n_out4p0 = n_out2p0 + n_out15p0;


// VectorOp:18
	vec3 n_out18p0 = n_out28p0 + vec3(n_out4p0.xyz);


// FloatParameter:12
	float n_out12p0 = alpha;


// FloatConstant:13
	float n_out13p0 = 0.000000;


// Output:0
	ALBEDO = n_out18p0;
	ALPHA = n_out12p0;
	ROUGHNESS = n_out13p0;
	EMISSION = vec3(n_out15p0.xyz);


}
