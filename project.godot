[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="player"
3d_physics/layer_3="interactable"
3d_physics/layer_4="battleAction"
3d_physics/layer_5="entity"
3d_physics/layer_6="enemy"

[physics]

3d/physics_engine="Jolt Physics"
common/physics_interpolation=true

[rendering]

textures/canvas_textures/default_texture_filter=3
textures/lossless_compression/force_png=true
lights_and_shadows/directional_shadow/size=1024
lights_and_shadows/directional_shadow/size.mobile=1024
textures/default_filters/use_nearest_mipmap_filter=true
anti_aliasing/screen_space_roughness_limiter/enabled=false
textures/decals/filter=2
textures/light_projectors/filter=2
environment/volumetric_fog/use_filter=0
environment/defaults/default_clear_color=Color(0.166406, 0.166406, 0.166406, 1)
viewport/transparent_background=true

[shader_globals]

precision_multiplier={
"type": "float",
"value": 1.0
}
resolution={
"type": "vec2",
"value": Vector2(896, 504)
}
colorDepth={
"type": "float",
"value": 24.0
}
