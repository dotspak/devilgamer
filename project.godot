; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Devilgamer"
config/tags=PackedStringArray("main", "rpg")
run/main_scene="uid://2obewctec8iv"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="uid://bckdxeqa5ykr3"

[audio]

buses/default_bus_layout="uid://ep0h8ybs1rmn"

[autoload]

GameConstants="*res://src/global/gameConstants.gd"
GameManager="*res://src/global/gameManager.tscn"
GameFlags="*res://src/global/flags.gd"
AudioManager="*res://src/global/audioManager.tscn"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
SceneManager="*res://src/global/sceneManager.gd"
PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
CameraManager="*res://src/global/cameraManager.tscn"

[dialogue_manager]

runtime/balloon_path="res://ui/dialogue/ui_msgBox2.tscn"
editor/new_file_template="~ start
Dummy, dummy, dummy!
=> END"

[display]

window/size/viewport_width=896
window/size/viewport_height=504
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="DevilBattleSystem"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/func_godot/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "orange",
"res://data/": "blue",
"res://dialogue/": "green",
"res://icons/": "gray",
"res://maps/": "orange",
"res://scenes/": "green",
"res://shaders/": "green",
"res://src/": "green",
"res://test/": "gray",
"res://textures/": "orange",
"res://ui/": "blue"
}

[global_group]

player="all nodes related to the overworld player"
climbable="objects that can be climbed"
interactable=""
enemy="Group for all enemy entites"
actor="Group for all allied entities"

[gui]

theme/custom="res://ui/defaultTheme.tres"

